# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Go API listens on
API_PORT=8080

# SQLite database file path (relative to where you run the binary)
DB_PATH=data.db

# Runtime environment label (development | staging | production)
ENV=development

# Comma-separated allowed CORS origins. Use * for all (dev only).
CORS_ORIGINS=*
